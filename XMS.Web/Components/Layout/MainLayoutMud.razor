@using XMS.Web.Components.Layout.Sections
@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="@ThemeState.IsDarkMode" Theme="_myCustomTheme" />
<MudSnackbarProvider />
<MudDialogProvider />
<MudPopoverProvider />
<MudLayout>
	<MudAppBar Elevation="1" Class="mb-2">
		<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
		<MudText Typo="Typo.h5" Class="ml-3 mr-3">Предприятие</MudText>

		<MudTabs ActivePanelIndex="_activeIndex"
				 ActivePanelIndexChanged="SetSection"
				 Elevation="0"
				 ApplyEffectsToContainer="true"
				 Rounded="true"
				 Color="Color.Inherit"
				 Class="ml-5">
			@foreach (var section in _sections)
			{
				<MudTabPanel Text="@(section.Title)" Icon="@(section.Icon)" />
			}
		</MudTabs>
		<MudSpacer />
		<AuthOnAppBar />
		<MudIconButton Icon="@(ThemeState.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
					   title="@(ThemeState.IsDarkMode ? "Включить светлую тему" : "Включить тёмную тему")"
					   Color="Color.Inherit"
					   OnClick="ToggleThemeClick" />
		<MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End" />
	</MudAppBar>
	<MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
		@_currentSection?.Menu
	</MudDrawer>
	<MudMainContent>
		@Body
	</MudMainContent>
</MudLayout>

@code {
	[Inject] public IEnumerable<IAppSection> Sections { get; set; } = default!;
	[Inject] public IHttpContextAccessor HttpContextAccessor { get; set; } = default!;
	[Inject] public IJSRuntime JS { get; set; } = default!;
	[Inject] public NavigationManager Navigation { get; set; } = default!;
	[Inject] public ThemeState ThemeState { get; set; } = default!;

	private bool _drawerOpen = true;

	private List<IAppSection> _sections = new();
	private IAppSection? _currentSection;
	private int _activeIndex;


	protected override void OnInitialized()
	{
		var theme = HttpContextAccessor.HttpContext?
			.Request
			.Cookies[AppSettings.Theme.CookieName];

		ThemeState.SetTheme(theme);

		_sections = Sections.ToList();
		_currentSection = _sections.FirstOrDefault();
		_activeIndex = 0;
	}

	void DrawerToggle()
	{
		_drawerOpen = !_drawerOpen;
	}

	private void SetSection(int index)
	{
		if (index < 0 || index >= _sections.Count)
			return;

		_activeIndex = index;
		_currentSection = _sections[index];
		_drawerOpen = true;
	}

	private Task ToggleThemeClick(MouseEventArgs _)
	{
		return ToggleTheme(!ThemeState.IsDarkMode);
	}

	private async Task ToggleTheme(bool isDark)
	{
		var theme = isDark ? AppSettings.Theme.Dark : AppSettings.Theme.Light;

		ThemeState.SetTheme(theme);

		await JS.InvokeVoidAsync("appHttp.post", $"/ui/theme/{theme}");

		Navigation.Refresh();
	}

	private MudTheme _myCustomTheme = new MudTheme()
	{
		PaletteLight = new PaletteLight()
		{
			// Акценты (Indigo)
			Primary = "#6366F1",          // Indigo 500
			Secondary = "#64748B",        // Slate 500

			// Поверхности
			Background = "#F1F5F9",       // Slate 100
			AppbarBackground = "#E2E8F0",
			AppbarText = "#1E293B",
			DrawerBackground = "#FFFFFF", // Белый сайдбар
			Surface = "#FFFFFF",          // Карточки

			// Текст и линии
			TextPrimary = "#334155",      // Slate 700
			TextSecondary = "#64748B",    // Slate 500
			LinesDefault = "#E2E8F0",     // Slate 200 (сетка таблицы)
			TableStriped = "#F8FAFC",
			Divider = "#E2E8F0",

			// Статусы (Muted)
			Success = "#10B981",          // Emerald 500
			Error = "#EF4444",            // Red 500
			Info = "#3B82F6",             // Blue 500
			Warning = "#F59E0B",          // Amber 500
		},
		PaletteDark = new PaletteDark()
		{
			// Акценты (Indigo Light)
			Primary = "#818CF8",          // Indigo 400
			Secondary = "#94A3B8",        // Slate 400

			// Поверхности
			Background = "#0F172A",       // Slate 900 (глубокий синий)
			Surface = "#1E293B",          // Slate 800 (карточки)
			AppbarBackground = "#1E293B", // Slate 800
			DrawerBackground = "#1E293B", // Slate 800

			// Текст и линии
			TextPrimary = "#F1F5F9",
			TextSecondary = "#94A3B8",    // Slate 400
			LinesDefault = "#334155",     // Slate 700 (тонкие границы)
			TableStriped = "#242F3E",     // Кастомный Slate 850 (едва заметный)

			// Статусы
			Success = "#34D399",          // Emerald 400
			Error = "#F87171",            // Red 400
			Info = "#60A5FA",             // Blue 400
			Warning = "#FBBF24",          // Amber 400
		},
		LayoutProperties = new LayoutProperties()
		{
			DefaultBorderRadius = "8px"
		}
	};
}