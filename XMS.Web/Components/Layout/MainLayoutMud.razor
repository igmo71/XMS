@using XMS.Web.Components.Layout.Sections
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inherits LayoutComponentBase
@inject IEnumerable<IAppSection> Sections
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<MudThemeProvider @ref="@_mudThemeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="_myCustomTheme" />
<MudSnackbarProvider />
<MudDialogProvider />
<MudPopoverProvider />
<MudLayout>
	<MudAppBar Elevation="1" Class="mb-2">
		<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
		<MudText Typo="Typo.h5" Class="ml-3 mr-3">Предприятие</MudText>
		
		<MudTabs ActivePanelIndex="_activeIndex"
				 ActivePanelIndexChanged="SetSection"
				 Elevation="0"
				 ApplyEffectsToContainer="true"
				 Rounded="true"
				 Color="Color.Inherit"
				 Class="ml-5">
			@foreach (var section in _sections)
			{
				string tabPanelBackground = _isDarkMode ? _myCustomTheme.PaletteDark.AppbarBackground.Value : _myCustomTheme.PaletteLight.AppbarBackground.Value;
				<MudTabPanel Text="@(section.Title)" Icon="@(section.Icon)" Style="@($"background: {tabPanelBackground}")" />
			}
		</MudTabs>
		<MudSpacer />
		<AuthOnAppBar />
		<MudIconButton Icon="@_themeIcon" Color="Color.Inherit" OnClick="@CycleTheme" title="@_themeTitle" />
		<MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End" />
	</MudAppBar>
	<MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
		@_currentSection?.Menu
	</MudDrawer>
	<MudMainContent>
		@Body
	</MudMainContent>
</MudLayout>

@code {
	private bool _drawerOpen = true;
	private bool _isDarkMode = false;

	private List<IAppSection> _sections = new();
	private IAppSection? _currentSection;
	private int _activeIndex;

	private MudThemeProvider _mudThemeProvider = default!;

	private int _themeMode = 0;
	private string _themeIcon = Icons.Material.Filled.LightMode;
	private string _themeTitle = "Светлая тема";

	private MudTheme _myCustomTheme = new MudTheme()
	{
		PaletteLight = new PaletteLight()
		{
			// Акценты (Indigo)
			Primary = "#6366F1",          // Indigo 500
			Secondary = "#64748B",        // Slate 500

			// Поверхности
			Background = "#F1F5F9",       // Slate 100
			AppbarBackground = "#E2E8F0",
			AppbarText = "#1E293B",
			DrawerBackground = "#FFFFFF", // Белый сайдбар
			Surface = "#FFFFFF",          // Карточки

			// Текст и линии
			TextPrimary = "#334155",      // Slate 700
			TextSecondary = "#64748B",    // Slate 500
			LinesDefault = "#E2E8F0",     // Slate 200 (сетка таблицы)
			TableStriped = "#F8FAFC",
			Divider = "#E2E8F0",

			// Статусы (Muted)
			Success = "#10B981",          // Emerald 500
			Error = "#EF4444",            // Red 500
			Info = "#3B82F6",             // Blue 500
			Warning = "#F59E0B",          // Amber 500
		},
		PaletteDark = new PaletteDark()
		{
			// Акценты (Indigo Light)
			Primary = "#818CF8",          // Indigo 400
			Secondary = "#94A3B8",        // Slate 400

			// Поверхности
			Background = "#0F172A",       // Slate 900 (глубокий синий)
			Surface = "#1E293B",          // Slate 800 (карточки)
			AppbarBackground = "#1E293B", // Slate 800
			DrawerBackground = "#1E293B", // Slate 800

			// Текст и линии
			TextPrimary = "#F1F5F9",
			TextSecondary = "#94A3B8",    // Slate 400
			LinesDefault = "#334155",     // Slate 700 (тонкие границы)
			TableStriped = "#242F3E",     // Кастомный Slate 850 (едва заметный)

			// Статусы
			Success = "#34D399",          // Emerald 400
			Error = "#F87171",            // Red 400
			Info = "#60A5FA",             // Blue 400
			Warning = "#FBBF24",          // Amber 400
		},
		LayoutProperties = new LayoutProperties()
		{
			DefaultBorderRadius = "8px"
		}
	};

	protected override async Task OnInitializedAsync()
	{
		_sections = Sections.ToList();
		_currentSection = _sections.First();
		_activeIndex = 0;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_themeMode = await LocalStorage.GetItemAsync<int>(nameof(_themeMode));
			await ApplyThemeMode();
			StateHasChanged();
		}
	}

	void DrawerToggle()
	{
		_drawerOpen = !_drawerOpen;
	}

	private void SetSection(int index)
	{
		if (index < 0 || index >= _sections.Count)
			return;

		_activeIndex = index;
		_currentSection = _sections[index];
		_drawerOpen = true;
	}

	private async Task CycleTheme()
	{
		_themeMode = (_themeMode + 1) % 3;
		await ApplyThemeMode();
	}

	private async Task ApplyThemeMode()
	{
		switch (_themeMode)
		{
			case 0: // Системная
				_isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
				_themeIcon = Icons.Material.Filled.LightMode;
				_themeTitle = "Светлая тема";
				break;
			case 1: // Светлая
				_isDarkMode = false;
				_themeIcon = Icons.Material.Filled.DarkMode;
				_themeTitle = "Темная тема";
				break;
			case 2: // Темная
				_isDarkMode = true;
				_themeIcon = Icons.Material.Filled.SettingsBrightness;
				_themeTitle = "Системная тема";
				break;
		}
		
		await LocalStorage.SetItemAsync(nameof(_themeMode), _themeMode);
	}
}