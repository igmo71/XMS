@page "/cost-section/cost-allocation"
@using Microsoft.AspNetCore.Authorization
@using XMS.Integration.OneC.Ut.Features.Document_РасходныйКассовыйОрдер_Feature
@using XMS.Integration.OneC.Ut.Features.Document_СписаниеБезналичныхДенежныхСредств_Feature
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-3">
	<MudPaper Class="pa-4 mb-3">
		<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center">
			<MudText Typo="Typo.h5">Распределение затрат</MudText>
			<MudSpacer />
			<MudDatePicker Label="С" @bind-Date="_from" Editable="true" />
			<MudDatePicker Label="По" @bind-Date="_to" Editable="true" />
			<MudTextField T="string"
						  Label="Номер документа"
						  @bind-Value="_numberTerm"
						  Immediate="true"
						  Clearable="true" />
			<MudButton Variant="Variant.Filled"
					   Color="Color.Primary"
					   Disabled="_isLoading"
					   OnClick="ReloadAsync"
					   StartIcon="@Icons.Material.Filled.Sync">
				Обновить
			</MudButton>
		</MudStack>
	</MudPaper>

	<MudPaper Class="pa-4 mb-3 w-100">
		<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
			<MudText Typo="Typo.h6">Расходные кассовые ордера</MudText>
			<MudSpacer />
			<MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
				@_expenseCashOrders.Count записей
			</MudChip>
		</MudStack>

		<MudDataGrid Items="@_expenseCashOrders" Layout="TableLayout.Fixed"
					 T="Document_РасходныйКассовыйОрдер"
					 ReadOnly="true"
					 Filterable="true"
					 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
					 FilterMode="DataGridFilterMode.ColumnFilterRow"
					 SortMode="SortMode.Multiple"
					 Bordered="true"
					 Striped="true"
					 Hover="true"
					 Dense="true"
					 Loading="@_isLoading">
			<Columns>
				<PropertyColumn Property="x => x.Number" Title="Номер" Filterable="false" />
				<TemplateColumn Title="Дата">
					<CellTemplate>
						@context.Item.Date.ToString("dd.MM.yyyy")
					</CellTemplate>
				</TemplateColumn>
				<TemplateColumn Title="Сумма">
					<CellTemplate>
						@context.Item.СуммаДокумента.ToString("N2")
					</CellTemplate>
				</TemplateColumn>
				<PropertyColumn Property="x => x.ХозяйственнаяОперация" Title="Операция" />
				<PropertyColumn Property="x => x.Выдать" Title="Получатель" />
				<PropertyColumn Property="x => x.Комментарий" Title="Комментарий" />
			</Columns>
			<LoadingContent>
				<MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">
					Загружаем документы...
				</MudAlert>
			</LoadingContent>
			<NoRecordsContent>
				<MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">
					Документы не найдены.
				</MudAlert>
			</NoRecordsContent>
			<PagerContent>
				<MudDataGridPager T="Document_РасходныйКассовыйОрдер" />
			</PagerContent>
		</MudDataGrid>
	</MudPaper>

	<MudPaper Class="pa-4 w-100">
		<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
			<MudText Typo="Typo.h6">Списания безналичных денежных средств</MudText>
			<MudSpacer />
			<MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
				@_cashlessWriteOffs.Count записей
			</MudChip>
		</MudStack>

		<MudDataGrid Items="@_cashlessWriteOffs"
					 T="Document_СписаниеБезналичныхДенежныхСредств"
					 ReadOnly="true"
					 Filterable="true"
					 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
					 FilterMode="DataGridFilterMode.ColumnFilterRow"
					 SortMode="SortMode.Multiple"
					 Bordered="true"
					 Striped="true"
					 Hover="true"
					 Dense="true"
					 Loading="@_isLoading">
			<Columns>
				<PropertyColumn Property="x => x.Number" Title="Номер" Filterable="false" />
				<TemplateColumn Title="Дата">
					<CellTemplate>
						@context.Item.Date.ToString("dd.MM.yyyy")
					</CellTemplate>
				</TemplateColumn>
				<TemplateColumn Title="Сумма">
					<CellTemplate>
						@context.Item.СуммаДокумента.ToString("N2")
					</CellTemplate>
				</TemplateColumn>
				<PropertyColumn Property="x => x.ХозяйственнаяОперация" Title="Операция" />
				<PropertyColumn Property="x => x.НазначениеПлатежа" Title="Назначение платежа" />
				<PropertyColumn Property="x => x.Комментарий" Title="Комментарий" />
			</Columns>
			<LoadingContent>
				<MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">
					Загружаем документы...
				</MudAlert>
			</LoadingContent>
			<NoRecordsContent>
				<MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">
					Документы не найдены.
				</MudAlert>
			</NoRecordsContent>
			<PagerContent>
				<MudDataGridPager T="Document_СписаниеБезналичныхДенежныхСредств" />
			</PagerContent>
		</MudDataGrid>
	</MudPaper>
</MudContainer>
