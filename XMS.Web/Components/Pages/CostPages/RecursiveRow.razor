@using XMS.Domain.Models

@foreach (var category in CostCategories.Where(e => e.ParentId == ParentId))
{
	<MudTr>
		<MudTd DataLabel="Наименование" Style="@($"padding-left: {(Level * 24)}px;")">
			<div class="d-flex align-center">
				<MudIcon Icon="@Icons.Material.Filled.FolderOpen"
						 Class="@(category.IsDeleted ? "mr-2 text-secondary" : "mr-2")" Title="Категория Затрат" />
				<MudText Typo="Typo.body1"
						 Class="@(category.IsDeleted ? "text-secondary text-decoration-line-through" : "")">
					@category.Name
				</MudText>
			</div>
		</MudTd>
	</MudTr>
	
	<RecursiveRow CostCategories="CostCategories"
				  CostItems="CostItems"
				  CostCategoryItems="CostCategoryItems"
				  CashFlowItems="CashFlowItems"
				  ParentId="category.Id"
				  Level="@(Level + 1)">
	</RecursiveRow>

	@if (category.Items?.Count > 0)
	{
		foreach (var item in category.Items)
		{
			<MudTr>
				<MudTd DataLabel="Наименование" Style="@($"padding-left: {(Level + 1) * 24}px;")">
					@* Обертка для позиционирования *@
					<div class="d-flex align-center justify-space-between w-50">
                    
						@* Левая часть: Иконка + Текст *@
						<div class="d-flex align-center">
							<MudIcon Icon="@Icons.Material.Filled.Description"
									 Size="Size.Small"
									 Color="@(item.IsDeleted ? Color.Secondary : Color.Default)"
									 Class="mr-2" Title="Статья Затрат" />
							<MudText Typo="Typo.body2"
									 Class="@(item.IsDeleted ? "text-secondary text-decoration-line-through" : "")">
								@item.Name
							</MudText>
						</div>

						@* Правая часть: Чип *@
						@{
							var cashFlowName = GetCashFlowItem(category, item);
						}
						@if (!string.IsNullOrEmpty(cashFlowName))
						{
							<MudButton Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.Delete" Color="Color.Primary">@cashFlowName</MudButton>
						}
						else
						{
							<MudMenu AnchorOrigin="Origin.CenterRight" TransformOrigin="Origin.CenterLeft">
								<ActivatorContent>
									<MudIconButton Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@context.ToggleAsync" />
								</ActivatorContent>
								<ChildContent>
									<MudTreeView Items="@(_cashFlowtreeItems)" T="CashFlowItem" Dense="true">
										<ItemTemplate Context="item">
											<MudTreeViewItem Expanded="@item.Expanded"
															 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
															 Items="@item.Children"
															 Value="@item.Value">
												<Content>
													<MudTreeViewItemToggleButton Expanded="@item.Expanded"
																				 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
																				 Visible="@item.HasChildren" />
													<MudIcon Icon="@GetIcon(item)"
															 Class="@(item.Value?.IsDeleted == true ? "mr-2 text-secondary" : "mr-2")" />
													
													<MudStack Row="true" Class="d-flex justify-space-between flex-grow-1 gap-4">
														<MudText Typo="@(item.HasChildren? Typo.body1: Typo.body2)"
																 Class="@(item.Value?.IsDeleted == true ? "text-secondary text-decoration-line-through" : "")">
															@if (item.Value?.IsFolder == false)
															{
																<MudMenuItem Class="py-0">
																	@item.Value?.Name
																</MudMenuItem>
															}
															else
															{
																@item.Value?.Name
															}
														</MudText>
														<MudText>@item.Value?.Code</MudText>
													</MudStack>
												</Content>
											</MudTreeViewItem>
										</ItemTemplate>
									</MudTreeView>
								</ChildContent>
							</MudMenu>
						}
					</div>
				</MudTd>
			</MudTr>
		}
	}
}

@code {
	[Parameter] public IReadOnlyList<CostCategory> CostCategories { get; set; } = default!;
	[Parameter] public IEnumerable<CostItem> CostItems { get; set; } = default!;
	[Parameter] public IReadOnlyList<CostCategoryItem> CostCategoryItems { get; set; } = default!;
	[Parameter] public IReadOnlyList<CashFlowItem> CashFlowItems { get; set; } = default!;
	[Parameter] public Guid? ParentId { get; set; }
	[Parameter] public int Level { get; set; } = 0;

	private IReadOnlyList<TreeItemData<CashFlowItem>> _cashFlowtreeItems = [];
	private HashSet<Guid> _expandedCashFlowItemIds = [];

	private string? GetCashFlowItem(CostCategory costCategory, CostItem costItem)
	{
		var costCategoryItem = CostCategoryItems.FirstOrDefault(e => e.CategoryId == costCategory.Id && e.ItemId == costItem.Id);

		if (costCategoryItem is null) return null;

		var cashFlowItem = CashFlowItems.FirstOrDefault(e => e.Id == costCategoryItem.CashFlowItemId);

		return cashFlowItem?.Name;
	}

	protected override void OnInitialized()
	{
		BuildTree();
	}

	private void BuildTree()
	{
		_cashFlowtreeItems = ExecuteBuildTree(CashFlowItems, Guid.Parse("00000000-0000-0000-0000-000000000000"));

		StateHasChanged();
	}

	private static List<TreeItemData<CashFlowItem>> ExecuteBuildTree(IEnumerable<CashFlowItem> allItems, Guid? parentId)
	{
		var list = allItems
			.Where(e => e.ParentId == parentId).ToList();
		var result = list
		.Select(e => new TreeItemData<CashFlowItem>
		{
			Value = e,
			Text = e.Name,
			Expanded = false,
			Children = ExecuteBuildTree(allItems, e.Id)
		})
		.ToList();

		return result;
	}
	private async Task ExpandedChanged(ITreeItemData<CashFlowItem?> node, bool expanded)
	{
		node.Expanded = expanded;

		if (node.Value is CashFlowItem cashFlowItem)

		{
			if (expanded)
				_expandedCashFlowItemIds.Add(cashFlowItem.Id);
			else
				_expandedCashFlowItemIds.Remove(cashFlowItem.Id);
		}
	}

	private static string GetIcon(ITreeItemData<CashFlowItem> item)
	{
		if (item.HasChildren)
			return item.Expanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder;

		return Icons.Material.Filled.Description;
	}

}

