@page "/costitems-cashflowitems"
@using Microsoft.AspNetCore.Authorization
@using XMS.Domain.Models
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-4">
	<MudPaper Style=" max-height: calc(100vh - 96px); overflow-y: auto;">
		<RecursiveTable CostCategories="_costCategories"
						CostItems="_costItems"
						CostCategoryItems="_costCategoryItems"
						CashFlowItems="_cashFlowItems"
						ParentId="null">
		</RecursiveTable>
	</MudPaper>
</MudContainer>