@page "/costitems-cashflowitems"
@using Microsoft.AspNetCore.Authorization
@using XMS.Domain.Models
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Medium" Class="pt-4">
	<MudPaper Style="max-height: calc(100vh - 96px); overflow-y: auto;">
		<RecursiveTable @ref="_recursiveTable" CostCategories="_costCategories"
						CostCategoryItems="_costCategoryItems"
						CashFlowItems="_cashFlowItems"
						ParentId="null" 
						OnAddCashFlowItemLink="AddCashFlowItemLink"
						OnDeleteCashFlowItemLink="DeleteCashFlowItemLink">
		</RecursiveTable>
	</MudPaper>
</MudContainer>