@page "/cashflow-cost"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-4">
	<MudPaper Style="max-height: calc(100vh - 96px); overflow-y: auto;">
		@if (_isLoading)
		{
			<MudProgressLinear Color="Color.Primary" Indeterminate="true" />
		}
		
		<RecursiveTable CostCategoryItemMap="_costCategoryItemMap"
						CostCatalogUtLookup="_costCatalogUtLookup"
						CatalogUtItemsTree="_catalogUtItemsTree"
						ParentId="null"
						OnUpdateCostCatalog="UpdateCostCatalogUt"
						OnDeleteCostCatalogUt="DeleteCostCatalogUt"
						CostCategoriesLookup="_costCategoriesLookup">
		</RecursiveTable>
		
	</MudPaper>
</MudContainer>