@page "/cashflow-cost"
@using Microsoft.AspNetCore.Authorization
@using XMS.Domain.Models
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-4">
	<MudPaper Style="max-height: calc(100vh - 96px); overflow-y: auto;">
		@if (_isLoading)
		{
			<MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
		}
		
		<RecursiveTable CostCategories="_costCategories"
						CostCategoryItemMap="_costCategoryItemMap"
						CashFlowCostLookup="_cashFlowCostLookup"
						CashFlowItemsTree="_cashFlowItemsTree"
						ParentId="null"
						OnUpdateCashFlowCosts="UpdateCashFlowCosts"
						OnDeleteCashFlowCost="DeleteCashFlowCost">
		</RecursiveTable>
		
	</MudPaper>
</MudContainer>