@using XMS.Application.Abstractions.Services
@using XMS.Domain.Models
@inject ICashFlowCostService CashFlowCostService

<MudToggleIconButton @bind-Toggled="@_open"
					 Icon="@Icons.Material.Filled.Add"
					 Color="@Color.Primary"
					 ToggledIcon="@Icons.Material.Filled.FullscreenExit"
					 ToggledColor="@Color.Secondary"
					 Size="Size.Small" />

<MudDrawer @bind-Open="@_open"
		   Anchor="Anchor.End"
		   ClipMode="DrawerClipMode.Always"
		   Elevation="1"
		   Variant="@DrawerVariant.Temporary"
		   OverlayAutoClose="false"
		   Width="800px"
		   Class="me-5">
	<MudDrawerHeader>
		<MudText Typo="Typo.h6">Статьи ДДС</MudText>
	</MudDrawerHeader>
	<MudPaper Style="max-height: calc(100vh - 200px); overflow-y: auto;">
		<MudTreeView Items="@(CashFlowItemsTree)" T="CashFlowItem" Dense="true">
			<ItemTemplate Context="item">
				<MudTreeViewItem Expanded="@item.Expanded"
								 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
								 Items="@item.Children"
								 Value="@item.Value">
					<Content>
						<MudTreeViewItemToggleButton Expanded="@item.Expanded"
													 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
													 Visible="@item.HasChildren" />
						<MudIcon Icon="@GetIcon(item)" Class="@(item.Value?.IsDeleted == true ? "mr-2 text-secondary" : "mr-2")" />
													
						<MudStack Row="true" Class="d-flex justify-space-between flex-grow-1 gap-4">
							@if (item.Value?.IsFolder == false)
							{
								<MudCheckBox T="bool"
											 Value="@(_selectedCashFlowItemIds.Contains(item.Value.Id))"
											 ValueChanged="@((bool isChecked) => CheckBoxChanged(isChecked, item.Value.Id))">
									<MudText Typo="Typo.body1">@item.Value?.Name</MudText>
								</MudCheckBox>
							}
							else
							{
								<MudText Typo="Typo.body1">@item.Value?.Name</MudText>
							}
							<MudText>@item.Value?.Code</MudText>
						</MudStack>
					</Content>
				</MudTreeViewItem>
			</ItemTemplate>
		</MudTreeView>		
	</MudPaper>	
	@if (_isProcessing)
	{
		<MudProgressLinear Color="Color.Primary" Indeterminate="true" />
	}
	<MudStack Row="true" Class="mt-2" Justify="Justify.SpaceAround">
		<MudButton OnClick="@UpdateCashFlowСosts" Color="Color.Primary" Variant="Variant.Filled">Сохранить</MudButton>
		<MudButton OnClick="@ToggleOpen" Color="Color.Secondary" Variant="Variant.Filled">Закрыть</MudButton>
	</MudStack>
</MudDrawer>

@code {
	[Parameter] public Guid CostCategoryItemId { get; set; } = default!;
	[Parameter] public IReadOnlyList<TreeItemData<CashFlowItem>> CashFlowItemsTree { get; set; } = default!;
	[Parameter] public HashSet<Guid> SelectedCashFlowItemIds { get; set; } = default!;
	[Parameter] public EventCallback<List<CashFlowCost>> OnUpdateCashFlowCosts { get; set; }

	private HashSet<Guid> _expandedCashFlowItemIds = [];
	private HashSet<Guid> _selectedCashFlowItemIds = [];

	private bool _open;
	private bool _isProcessing;

	protected override async Task OnInitializedAsync()
	{
		_selectedCashFlowItemIds = SelectedCashFlowItemIds;
	}

	private void ToggleOpen() => _open = !_open;

	private async Task ExpandedChanged(ITreeItemData<CashFlowItem?> node, bool expanded)
	{
		node.Expanded = expanded;

		if (node.Value is CashFlowItem cashFlowItem)

		{
			if (expanded)
				_expandedCashFlowItemIds.Add(cashFlowItem.Id);
			else
				_expandedCashFlowItemIds.Remove(cashFlowItem.Id);
		}
	}

	private static string GetIcon(ITreeItemData<CashFlowItem> item)
	{
		if (item.HasChildren)
			return item.Expanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder;

		return Icons.Material.Filled.Description;
	}

	private void CheckBoxChanged(bool isChecked, Guid itemId)
	{
		if (isChecked)
		{
			_selectedCashFlowItemIds.Add(itemId);
		}
		else
		{
			_selectedCashFlowItemIds.Remove(itemId);
		}
	}

	private async Task UpdateCashFlowСosts()
	{
		_isProcessing = true;
		var newCashFlowCostList = _selectedCashFlowItemIds
			.Select(e => new CashFlowCost { CashFlowItemId = e, CostCategoryItemId = CostCategoryItemId })
			.ToList();

		await OnUpdateCashFlowCosts.InvokeAsync(newCashFlowCostList);
		
		_isProcessing = false;
		ToggleOpen();
	}
}
