@using XMS.Integration.OneC.Ut.Models
@using XMS.Modules.CostModule.Abstractions
@using XMS.Modules.CostModule.Domain
@inject ICashFlowCostService CashFlowCostService

<MudToggleIconButton @bind-Toggled="@_open"
					 Icon="@Icons.Material.Filled.Add"
					 Color="@Color.Primary"
					 ToggledIcon="@Icons.Material.Filled.FullscreenExit"
					 ToggledColor="@Color.Secondary"
					 Size="Size.Small" />
@if (_open)
{
	<MudDrawer @bind-Open="@_open"
			   Anchor="Anchor.End"
			   ClipMode="DrawerClipMode.Always"
			   Elevation="1"
			   Variant="@DrawerVariant.Temporary"
			   OverlayAutoClose="false"
			   Width="800px"
			   Class="me-5">
		<MudDrawerHeader>
			<MudText Typo="Typo.h6">Статьи ДДС (1С Бух)</MudText>
		</MudDrawerHeader>
		<MudPaper Style="max-height: calc(100vh - 200px); overflow-y: auto;">
			<MudTreeView Items="@(CashFlowItemsTree)" T="Catalog_СтатьиДвиженияДенежныхСредств" Dense="true">
				<ItemTemplate Context="item">
					<MudTreeViewItem Expanded="@item.Expanded"
									 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
									 Items="@item.Children"
									 Value="@item.Value">
						<Content>
							<MudTreeViewItemToggleButton Expanded="@item.Expanded"
														 ExpandedChanged="@((expanded) => ExpandedChanged(item, expanded))"
														 Visible="@item.HasChildren" />
							<MudIcon Icon="@GetIcon(item)" Class="@(item.Value?.DeletionMark == true ? "mr-2 text-secondary" : "mr-2")" />

							<MudStack Row="true" Class="d-flex justify-space-between flex-grow-1 gap-4">
								@if (item.Value?.IsFolder == false)
								{
									<MudCheckBox T="bool"
												 Value="@(SelectedCashFlowItemIds.Contains(item.Value.Ref_Key))"
												 ValueChanged="@((bool isChecked) => CheckBoxChanged(isChecked, item.Value.Ref_Key))">
										<MudText Typo="Typo.body1">@item.Value?.Description</MudText>
									</MudCheckBox>
								}
								else
								{
									<MudText Typo="Typo.body1">@item.Value?.Description</MudText>
								}
								<MudText>@item.Value?.Code</MudText>
							</MudStack>
						</Content>
					</MudTreeViewItem>
				</ItemTemplate>
			</MudTreeView>
		</MudPaper>
		@if (_isProcessing)
		{
			<MudProgressLinear Color="Color.Primary" Indeterminate="true" />
		}
		<MudStack Row="true" Class="mt-2" Justify="Justify.SpaceAround">
			<MudButton OnClick="@UpdateCashFlowСosts" Color="Color.Primary" Variant="Variant.Filled">Сохранить</MudButton>
			<MudButton OnClick="@ToggleOpen" Color="Color.Secondary" Variant="Variant.Filled">Закрыть</MudButton>
		</MudStack>
	</MudDrawer>
}

@code {
	[Parameter] public Guid CostCategoryItemId { get; set; } = default!;
	[Parameter] public IReadOnlyList<TreeItemData<Catalog_СтатьиДвиженияДенежныхСредств>> CashFlowItemsTree { get; set; } = default!;
	[Parameter] public HashSet<Guid> SelectedCashFlowItemIds { get; set; } = default!;
	[Parameter] public EventCallback<List<CostCatalog_СтатьиДвиженияДенежныхСредств>> OnUpdateCashFlowCosts { get; set; }

	private HashSet<Guid> _expandedCashFlowItemIds = [];

	private bool _open;
	private bool _isProcessing;

	private void ToggleOpen() => _open = !_open;

	private async Task ExpandedChanged(ITreeItemData<Catalog_СтатьиДвиженияДенежныхСредств?> node, bool expanded)
	{
		node.Expanded = expanded;

		if (node.Value is Catalog_СтатьиДвиженияДенежныхСредств cashFlowItem)

		{
			if (expanded)
				_expandedCashFlowItemIds.Add(cashFlowItem.Ref_Key);
			else
				_expandedCashFlowItemIds.Remove(cashFlowItem.Ref_Key);
		}
	}

	private static string GetIcon(ITreeItemData<Catalog_СтатьиДвиженияДенежныхСредств> item)
	{
		if (item.HasChildren)
			return item.Expanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder;

		return Icons.Material.Filled.Description;
	}

	private void CheckBoxChanged(bool isChecked, Guid itemId)
	{
		if (isChecked)
		{
			SelectedCashFlowItemIds.Add(itemId);
		}
		else
		{
			SelectedCashFlowItemIds.Remove(itemId);
		}
	}

	private async Task UpdateCashFlowСosts()
	{
		_isProcessing = true;
		var newCashFlowCostList = SelectedCashFlowItemIds
			.Select(e => new CostCatalog_СтатьиДвиженияДенежныхСредств { CatalogRefKey = e, CostCategoryItemId = CostCategoryItemId })
			.ToList();

		await OnUpdateCashFlowCosts.InvokeAsync(newCashFlowCostList);
		
		_isProcessing = false;
		ToggleOpen();
	}
}
