###############################################################################
# Normalize text files
###############################################################################
* text=auto

###############################################################################
# .NET / Visual Studio (CRLF)
###############################################################################
*.sln     text eol=crlf
*.slnx    text eol=crlf
*.csproj  text eol=crlf
*.props   text eol=crlf
*.targets text eol=crlf
*.cs      text eol=crlf
*.razor   text eol=crlf
*.cshtml  text eol=crlf

###############################################################################
# Config / Web / Cross-platform (LF)
###############################################################################
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.config  text eol=lf
*.md      text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.html    text eol=lf

###############################################################################
# Docker / Linux
###############################################################################
Dockerfile      text eol=lf
*.dockerfile    text eol=lf
*.sh            text eol=lf

###############################################################################
# Windows scripts
###############################################################################
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# Binary files
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
*.pdb binary